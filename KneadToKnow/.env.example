# Firebase Configuration
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google Sign-In OAuth Client IDs
# Get these from: Google Cloud Console → APIs & Services → Credentials
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Anthropic API (for AI recipe parsing — used by Cloud Functions only in v2)
# For now, still in .env; will move to Cloud Functions config in Phase 2
EXPO_PUBLIC_CLAUDE_API_KEY=

# Home Assistant (per-user in v2 — stored in Firestore, proxied via Cloud Functions)
# These will be removed once Phase 2 (Cloud Functions) is complete
EXPO_PUBLIC_HA_URL=
EXPO_PUBLIC_HA_TOKEN=
EXPO_PUBLIC_HA_ENTITY_ID=
