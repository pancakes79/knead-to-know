# Firebase Configuration
# Get these from: Firebase Console → Project Settings → Your Apps → Config
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Anthropic API (for AI recipe parsing)
# Get this from: console.anthropic.com → API Keys
EXPO_PUBLIC_CLAUDE_API_KEY=

# Home Assistant (for automatic ambient temperature)
# URL: your HA instance, e.g., http://192.168.1.100:8123
# Token: HA → Profile → Long-Lived Access Tokens → Create Token
# Entity ID: HA → Developer Tools → States → search "temperature"
EXPO_PUBLIC_HA_URL=
EXPO_PUBLIC_HA_TOKEN=
EXPO_PUBLIC_HA_ENTITY_ID=
