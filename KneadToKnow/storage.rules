rules_version = '2';

// Knead to Know — Firebase Storage Security Rules
//
// HOW TO DEPLOY:
//   1. Go to Firebase Console → Storage → Rules tab
//   2. Replace the default rules with this entire file
//   3. Click "Publish"

service firebase.storage {
  match /b/{bucket}/o {
    
    // ─── Bake Photos ───
    // Photos are namespaced by user ID to enforce ownership
    match /bake-photos/{userId}/{recipeId}/{fileName} {
      // Authenticated users can read photos (needed to display shared recipes)
      allow read: if request.auth != null;

      // Only the owning user can upload/overwrite/delete their own photos
      allow write: if request.auth != null
        && request.auth.uid == userId
        // Must be an image
        && request.resource.contentType.matches('image/.*')
        // Max 10MB per photo
        && request.resource.size < 10 * 1024 * 1024;
    }
    
    // ─── Deny everything else ───
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
