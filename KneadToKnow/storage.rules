rules_version = '2';

// Knead to Know — Firebase Storage Security Rules
//
// HOW TO DEPLOY:
//   1. Go to Firebase Console → Storage → Rules tab
//   2. Replace the default rules with this entire file
//   3. Click "Publish"

service firebase.storage {
  match /b/{bucket}/o {
    
    // ─── Bake Photos ───
    // Photos are namespaced by user ID to enforce ownership
    match /bake-photos/{userId}/{recipeId}/{fileName} {
      allow read: if request.auth != null;

      // Allow deletion if they own it
      allow delete: if request.auth != null && request.auth.uid == userId;

      // Enforce size and type only on creation and updates
      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.contentType.matches('image/.*')
        && request.resource.size < 10 * 1024 * 1024;
    }
    
    // ─── Deny everything else ───
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
