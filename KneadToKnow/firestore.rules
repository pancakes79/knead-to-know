rules_version = '2';

// Knead to Know — Firestore Security Rules (v2 — multi-user)
//
// All collections require Firebase Auth. Recipes can be shared
// with the community via the visibility field.
//
// HOW TO DEPLOY:
//   1. Go to Firebase Console → Firestore Database → Rules tab
//   2. Replace the default rules with this entire file
//   3. Click "Publish"

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Users Collection ───
    // Users can only read/write their own document
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;

      // Config subcollection (HA url/entityId, non-secret fields) — owner read-only.
      // Writes happen via Cloud Functions (Admin SDK) to prevent tampering.
      match /config/{docId} {
        allow read: if request.auth.uid == userId;
      }

      // Private subcollection — owner only
      match /private/{docId} {
        allow read, write: if request.auth.uid == userId;
      }
    }

    // ─── Recipes Collection ───
    match /recipes/{recipeId} {
      allow read: if request.auth != null
                  && (resource.data.ownerId == request.auth.uid
                      || resource.data.visibility == 'shared');
      
      allow create: if request.auth != null
                    && request.resource.data.ownerId == request.auth.uid
                    && isValidRecipe();
                    
      // NEW: Ensure the ownerId cannot be mutated during an update
      allow update: if resource.data.ownerId == request.auth.uid
                    && request.resource.data.ownerId == resource.data.ownerId 
                    && isValidRecipe();
                    
      allow delete: if resource.data.ownerId == request.auth.uid;
    }

    // ─── Bakes Collection ───
    // Users can only access their own bake log entries
    match /bakes/{bakeId} {
      allow read: if request.auth != null
                  && resource.data.ownerId == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.ownerId == request.auth.uid
                    && isValidBake();
      allow update, delete: if resource.data.ownerId == request.auth.uid;
    }

    // ─── Rate Limits (managed by Cloud Functions via Admin SDK) ───
    // Clients should never read/write these directly
    match /rateLimits/{docId} {
      allow read, write: if false;
    }

    // ─── Deny everything else ───
    match /{document=**} {
      allow read, write: if false;
    }

    // ─── Validation Functions ───

    function isValidRecipe() {
      let data = request.resource.data;
      return data.keys().hasAll(['name', 'ingredients', 'steps', 'ownerId'])
        && data.name is string
        && data.name.size() > 0
        && data.name.size() <= 200
        && data.ingredients is list
        && data.steps is list
        && data.ownerId is string;
    }

    function isValidBake() {
      let data = request.resource.data;
      return data.keys().hasAll(['recipeId', 'rating', 'ownerId'])
        && data.recipeId is string
        && data.rating is number
        && data.rating >= 0
        && data.rating <= 5
        && data.ownerId is string;
    }
  }
}
